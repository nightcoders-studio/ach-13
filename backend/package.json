{
  "name": "habaget-api-backend-server",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "description": "Node backend for proxying Google Cloud API requests",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env.local server.js",
    "dev": "nodemon --env-file-if-exists=.env.local server.js",
    "check": "node --check server.js",
    "seed:admin": "node --env-file-if-exists=.env.local scripts/seed-admin.js"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "7.5.1",
    "firebase-admin": "13.10.0",
    "google-auth-library": "10.6.2",
    "node-fetch": "3.3.2",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "nodemon": "3.1.14"
  }
}
